---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="w-full max-w-6xl space-y-2">
  <div class="relative border border-default bg-offset px-6 pb-6 pt-8 rounded-lg shadow-sm">
    <!-- Título flotante -->
    <h3
      class="absolute right-4 top-0 -translate-y-1/2 rounded-full border border-current bg-default px-4 py-1 uppercase tracking-tight text-xs"
    >
      {title}
    </h3>

    <!-- Acordeón -->
    <div class="space-y-3 mt-4">
      <!-- Sección 1 -->
      <details class="group border border-gray-200 rounded-lg bg-transparent p-4 transition-all duration-300">
        <summary class="flex justify-between items-center cursor-pointer select-none">
          <h4 class="text-base font-semibold text-pink-400">🎉 Paquete A</h4>
          <span class="transition-transform duration-300 group-open:rotate-180 text-pink-400">⌄</span>
        </summary>
        <p class="mt-3 text-sm text-grey-600 leading-relaxed">
          Ideal para reuniones pequeñas. Incluye decoración base, luces cálidas, música ambiental
          y asistencia técnica básica.
        </p>
      </details>

      <!-- Sección 2 -->
      <details class="group border border-gray-200 rounded-lg bg-transparent p-4 transition-all duration-300">
        <summary class="flex justify-between items-center cursor-pointer select-none">
          <h4 class="text-base font-semibold text-pink-400">✨ Paquete B</h4>
          <span class="transition-transform duration-300 group-open:rotate-180 text-pink-400">⌄</span>
        </summary>
        <p class="mt-3 text-sm text-grey-600 leading-relaxed">
          Perfecto para celebraciones especiales. Incluye DJ en vivo, iluminación LED profesional,
          decoración personalizada y servicio completo.
        </p>
      </details>

      <!-- Sección 3 -->
      <details class="group border border-gray-200 rounded-lg bg-transparent p-4 transition-all duration-300">
        <summary class="flex justify-between items-center cursor-pointer select-none">
          <h4 class="text-base font-semibold text-pink-400">💎 Paquete C</h4>
          <span class="transition-transform duration-300 group-open:rotate-180 text-pink-400">⌄</span>
        </summary>
        <p class="mt-3 text-sm text-grey-600 leading-relaxed">
          La experiencia más completa: ambientación temática, equipo audiovisual premium,
          personal de apoyo y coordinación integral del evento.
        </p>
      </details>
    </div>
  </div>

  <p class="text-right text-sm mt-2">
    <a class="text-primary hover:underline" href="#">...ver más &rarr;</a>
  </p>
</div>


